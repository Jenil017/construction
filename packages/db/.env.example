# Neon Postgres connection string used by Drizzle Kit (migrate / push / studio) and the seed.
# `pnpm db:generate` does NOT need this — it diffs the schema offline.
DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"

# Seed credentials for `pnpm db:seed` (creates the first company + admin + default roles).
# Optional — the seed falls back to safe defaults if these are unset.
SEED_COMPANY_NAME="Demo Construction Co"
SEED_ADMIN_NAME="Admin"
SEED_ADMIN_EMAIL="admin@demo.test"
SEED_ADMIN_PASSWORD="change-me-strong-password"
